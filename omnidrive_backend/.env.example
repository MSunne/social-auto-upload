OMNIDRIVE_APP_NAME=OmniDrive API
OMNIDRIVE_ENV=development
OMNIDRIVE_API_V1_PREFIX=/api/v1
OMNIDRIVE_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/omnidrive
OMNIDRIVE_REDIS_URL=redis://127.0.0.1:6379/0
OMNIDRIVE_S3_ENDPOINT_URL=
OMNIDRIVE_S3_BUCKET=
OMNIDRIVE_S3_ACCESS_KEY=
OMNIDRIVE_S3_SECRET_KEY=
OMNIDRIVE_JWT_SECRET=change-me
OMNIDRIVE_ACCESS_TOKEN_EXPIRE_MINUTES=720
OMNIDRIVE_AUTO_CREATE_TABLES=true

