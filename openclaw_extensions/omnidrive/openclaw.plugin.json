{
  "id": "omnidrive",
  "skills": [
    "./skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string"
      },
      "accessToken": {
        "type": "string"
      },
      "email": {
        "type": "string"
      },
      "password": {
        "type": "string"
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 180000
      },
      "localOmniBullBaseUrl": {
        "type": "string"
      },
      "localOmniBullApiKey": {
        "type": "string"
      },
      "localOmniBullTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 180000
      },
      "localDeviceCode": {
        "type": "string"
      },
      "defaultChatModel": {
        "type": "string"
      },
      "defaultImageModel": {
        "type": "string"
      },
      "defaultVideoModel": {
        "type": "string"
      },
      "defaultVideoDurationSeconds": {
        "type": "integer",
        "minimum": 1,
        "maximum": 120
      }
    }
  }
}
